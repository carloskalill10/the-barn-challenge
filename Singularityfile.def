Bootstrap: docker
From: ros:melodic

%setup
    mkdir -p ${SINGULARITY_ROOTFS}/jackal_ws/src

%files
    . /jackal_ws/src/the-barn-challenge

%post -c /bin/bash
    apt -y update; apt-get -y install python3-venv ros-melodic-teb-local-planner  ros-melodic-costmap-converter python-scipy python-sklearn ros-melodic-tf ros-melodic-tf-conversions ros-melodic-tf2-ros 
  
    python3 -m venv /venv
    export PATH="/venv/bin:$PATH"
    pip3 install --upgrade pip
    pip3 install defusedxml rospkg netifaces numpy scipy sklearn

    cd /jackal_ws/src
    git clone https://github.com/jackal/jackal.git --branch melodic-devel
    git clone https://github.com/jackal/jackal_simulator.git --branch melodic-devel
    git clone https://github.com/jackal/jackal_desktop.git --branch melodic-devel
    git clone https://github.com/romulortr/fsmt_ros.git --branch barn2025
    git clone https://github.com/carloskalill10/mux_detector.git
    git clone https://github.com/carloskalill10/dynamic_obstacles_detector.git 
    git clone https://github.com/carloskalill10/jackal_barn_navigation.git

    source /opt/ros/melodic/setup.bash
    cd ..
    rosdep init; rosdep update --rosdistro melodic
    rosdep install -y --from-paths . --ignore-src --rosdistro=melodic
    source devel/setup.bash
    catkin_make

%environment
    export PATH="/venv/bin:$PATH"